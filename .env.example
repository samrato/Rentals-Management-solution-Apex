# Optional overrides for compose.yaml
CLIENT_PORT=8081
SERVER_PORT=5000
MONGO_PORT=27017
MONGO_DB=apex_rentals

# Required for auth flows beyond local smoke tests.
JWT_SECRET=local-dev-jwt-secret

# Optional third-party integrations. Leave blank for local-only runs.
GEMINI_API_KEY=
EMAIL_HOST=
EMAIL_USER=
EMAIL_PASS=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:5000/api/payments/callback
